RewriteEngine on

# 1. Force HTTPS and Non-WWW (Cleanest URL for SEO)
RewriteCond %{HTTP_HOST} ^(www\.)(.+) [OR]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(www\.)?(.+)
RewriteRule ^ https://%2%{REQUEST_URI} [R=301,L]

# 2. HSTS (Strict Transport Security)
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Prevents Clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  # Prevents MIME Sniffing
  Header always set X-Content-Type-Options "nosniff"
</IfModule>

# 3. Security: Block sensitive files (Apache 2.4 Syntax)
<FilesMatch "(\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|swp|env|json)|~)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# 4. Performance: Compression (GZIP)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript \
                                application/json \
                                application/x-font-ttf \
                                application/xml \
                                font/opentype \
                                image/svg+xml \
                                image/x-icon \
                                text/css \
                                text/html \
                                text/plain
</IfModule>

# 5. Performance: Leveraged Browser Caching (Expires)
<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresDefault                                      "access plus 1 month"

  # HTML (No cache para asegurar que los cambios se vean al publicar)
  ExpiresByType text/html                             "access plus 0 seconds"

  # CSS / JS (Astro genera hashes en el nombre, así que 1 año es seguro)
  ExpiresByType text/css                              "access plus 1 year"
  ExpiresByType application/javascript                "access plus 1 year"

  # Media / Fonts
  ExpiresByType image/avif                            "access plus 1 year"
  ExpiresByType image/webp                            "access plus 1 year"
  ExpiresByType font/woff2                            "access plus 1 year"
  ExpiresByType image/svg+xml                         "access plus 1 month"
</IfModule>

# 6. Clean URLs for Astro (Handle 404)
ErrorDocument 404 /404.html

# 7. Cross-Domain Fonts
<IfModule mod_headers.c>
  <FilesMatch "\.(eot|otf|ttc|ttf|woff|woff2)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>