root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = false
trim_trailing_whitespace = true
quote_type = single
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sh]
end_of_line = lf

[*.{astro,tsx,jsx,ts,js}]
indent_size = 2
trim_trailing_whitespace = true

[*.tf]
indent_size = 2