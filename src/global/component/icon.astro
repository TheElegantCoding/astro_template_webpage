---
import { capitalizeFirst } from '@global/util/string';

import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'svg'> &
{
  readonly name: string;
  readonly size?: number;
  readonly title?: string;
  readonly class?: string;
};

const {
  class: classIcon,
  name,
  size = 32,
  title,
  ...rest
} = Astro.props;

const modules = import.meta.glob<{ default: string }>(
  [ '/src/global/asset/icon/*.svg', '/src/module/**/asset/icon/*.svg' ],
  {
    eager: true,
    query: '?raw'
  }
);

const iconPath = Object.keys(modules).find((path) => path.endsWith(`/${name}.svg`));
const rawSvg = iconPath ? modules[iconPath]?.default : undefined;

if(!rawSvg)
{
  throw new Error(`Icon "${name}" not found in global or module assets.`);
}

const innerSVG = (rawSvg as string)
  .replace(/<svg[^>]*>/, '')
  .replace(/<\/svg>/, '')
  .replaceAll(/fill=".*?"/g, 'fill="currentColor"');

const iconTitle = title ? `<title>${capitalizeFirst(title)}</title>` : '';
---
<svg
  width={size}
  height={size}
  viewBox='0 0 64 64'
  class:list={classIcon}
  xmlns='http://www.w3.org/2000/svg'
  set:html={`${iconTitle}${innerSVG}`}
  aria-hidden={title ? 'false' : 'true'}
  {...rest}
/>