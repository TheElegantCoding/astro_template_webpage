---
import { siteConfiguration } from '@global/configuration/site_configuration';

const shouldRender = siteConfiguration.googleAnalyticId && import.meta.env.PROD;
---
{shouldRender && (
  <script
    async
    is:inline
    type='text/partytown'
    src={`https://www.googletagmanager.com/gtag/js?id=${siteConfiguration.googleAnalyticId}`}
  />
  <script
    is:inline
    type='text/partytown'
    define:vars={{ siteConfiguration }}
  >
    window.dataLayer ||= [];
    const gtag = (...args) =>
    {
      dataLayer.push(args);
    };
    gtag('js', new Date());
    gtag('config', siteConfiguration.googleAnalyticId);
  </script>
)}