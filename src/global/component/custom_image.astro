---
import Skeleton from '@global/component/skeleton.astro';
import { removeTrailingSlash } from '@global/util/link';
import { replaceExtension } from '@global/util/replace_extension';

import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'img'> & {
  readonly src: string;
  readonly alt: string;
  readonly priority?: boolean;
  readonly classSkeleton?: string;
  readonly disableLoader?: boolean;
  readonly classContainer?: string;
  readonly formats?: Array<'avif' | 'webp'>;
};

const {
  alt,
  class: classImage,
  classContainer,
  classSkeleton,
  disableLoader,
  formats = [ 'avif', 'webp' ],
  priority = false,
  src: source,
  ...rest
} = Astro.props;

const baseUrl = removeTrailingSlash(Astro.site?.toString() || '');
const imageUrl = source.startsWith('http') ? source : `${baseUrl}${source}`;
---
<Skeleton
  class='custom-image'
  isLoading={!disableLoader}
  class:list={classSkeleton}
>
  <picture class:list={classContainer}>
    {formats.includes('avif') && (
      <source type='image/avif' srcset={replaceExtension(imageUrl, 'avif')} />
    )}
    {formats.includes('webp') && (
      <source type='image/webp' srcset={replaceExtension(imageUrl, 'webp')} />
    )}
    <img
      alt={alt}
      src={imageUrl}
      class='custom-image__tag'
      class:list={[ classImage ]}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'auto' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
      {...rest}
    />
  </picture>
</Skeleton>

<script>
  const skeleton = document.querySelectorAll('.custom-image');

  skeleton.forEach((item) => {
    const image = item.querySelector('img');

    const onImageError = (event: Event) =>
    {
      const currentImage = event.currentTarget as HTMLImageElement;
      currentImage.src = image?.src as string;
    };

    const hideSkeleton = () => {
      item.classList.remove('skeleton--active');
    };

    if (image?.complete) {
      hideSkeleton();
    } else {
      image?.addEventListener('load', hideSkeleton);
      image?.addEventListener('error', onImageError);
    }
  });
</script>