---
import { removeTrailingSlash } from '@global/util/link';

const siteUrl = Astro.site ? removeTrailingSlash(Astro.site) : '';
const faviconPath = `${siteUrl}/asset/favicon`;
---
<link
  rel='icon'
  sizes='96x96'
  type='image/png'
  href={`${faviconPath}/favicon-96x96.png`}
/>
<link
  rel='icon'
  type='image/svg+xml'
  href={`${faviconPath}/favicon.svg`}
/>
<link
  rel='shortcut icon'
  href={`${faviconPath}/favicon.ico`}
/>
<link
  sizes='180x180'
  rel='apple-touch-icon'
  href={`${faviconPath}/apple-touch-icon.png`}
/>