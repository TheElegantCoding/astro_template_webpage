---
import { siteConfiguration } from '@global/configuration/site_configuration';
import { joinString } from '@global/util/string';

type Props = {
  readonly copyright?: string;
  readonly author?: {
    readonly web?: string;
    readonly name?: string;
    readonly email?: string;
  };
};

const {
  author = siteConfiguration.author,
  copyright = siteConfiguration.copyright
} = Astro.props;
---
{(author.name || author.email || author.web) && (
  <meta
    name='author'
    content={joinString([
      author.name,
      author.email,
      author.web
    ])}
  />
)}
{copyright && (<meta name='copyright' content={copyright} />)}