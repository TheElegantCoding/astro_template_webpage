---
import type { OpenGraphProfileType } from '@global/type/open_graph_type';

type Props = OpenGraphProfileType;

const {
  firstName,
  gender,
  lastName,
  username
} = Astro.props;
---
{firstName && (<meta content={firstName} property='profile:first_name' />)}
{lastName && (<meta content={lastName} property='profile:last_name' />)}
{username && (<meta content={username} property='profile:username' />)}
{gender && (<meta content={gender} property='profile:gender' />)}