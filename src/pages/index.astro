---
import Illustration from '@global/component/illustration.astro';
import BaseLayout from '@global/layout/base_layout.astro';
import { logger } from '@global/util/logger';

logger.error('Error de ejemplo: Esto es solo una demostración de logging en Astro.');
logger.warning('Advertencia de ejemplo: Esto es solo una demostración de logging en Astro.');
logger.info('Información de ejemplo: Esto es solo una demostración de logging en Astro.');
logger.success('Éxito de ejemplo: Esto es solo una demostración de logging en Astro.');
logger.debug('Depuración de ejemplo: Esto es solo una demostración de logging en Astro.');
---
<BaseLayout
  metaData={{
    description: 'El template de Astro para tu página web personal o portafolio profesional. Rápido, optimizado y fácil de personalizar.',
    keywords: [
      'Desarrollo Web',
      'Astro Framework',
      'React',
      'SEO Avanzado'
    ],
    title: 'AstraLight'
  }}
>
  <div class='hero'>
    <Illustration name='logo_astro' />
    <h1 class='hero__title'>AstraLight</h1>
  </div>
</BaseLayout>

<script>
  import { logger } from "@global/util/logger";

  logger.error('Error de ejemplo en el script: Esto es solo una demostración de logging en Astro.');
  logger.info('Información de ejemplo en el script: Esto es solo una demostración de logging en Astro.');
  logger.success('Éxito de ejemplo en el script: Esto es solo una demostración de logging en Astro.');
  logger.warning('Advertencia de ejemplo en el script: Esto es solo una demostración de logging en Astro.');
  logger.debug('Depuración de ejemplo en el script: Esto es solo una demostración de logging en Astro.');
</script>