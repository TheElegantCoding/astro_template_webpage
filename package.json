{
  "name": "astro_template_webpage",
  "description": "📦️ This repository that contains an Astro template ready for any website you can imagine. It's like a Swiss Army knife for developers, offering pre-built modules and flexible configurations to kickstart your project, regardless of its type.",
  "author": "Luis Monsalve <TheElegantCoder>, Astralys Software <astralysoftware.com>",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "astro dev",
    "check": "astro check",
    "preview": "astro preview",
    "build": "rimraf ./dist && astro check && astro build",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint ./src/**/*.{scss,css} --fix",
    "compress:convert": "pnpm compress:svg && pnpm convert:image && pnpm convert:typography",
    "compress:svg": "npx tsx ./script/compression/svg.ts",
    "convert:typography": "npx tsx ./script/conversion/typography.ts",
    "convert:image": "npx tsx ./script/conversion/image.ts",
    "deploy": "pnpm build && pnpm deploy:sync",
    "deploy:sync": "aws s3 sync ./dist 's3://BUCKECT-NAME.com/' --cache-control max-age=604800",
    "deploy:invalidate": "aws cloudfront create-invalidation --distribution-id DISTRIBUTION-ID --paths '/*'"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/partytown": "2.1.6",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fullhuman/postcss-purgecss": "8.0.0",
    "@types/node": "25.5.0",
    "@types/ttf2woff": "^2.0.4",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "6.1.3",
    "astro-class-shortener": "^1.0.3",
    "astro-inline-css": "^1.1.0",
    "autoprefixer": "10.4.27",
    "beasties": "^0.4.1",
    "eslint-config-universal-code": "^1.0.5",
    "lenis": "^1.3.21",
    "postcss": "8.5.8",
    "rimraf": "6.1.3",
    "sass": "1.98.0",
    "sharp": "^0.34.5",
    "stylelint-config-universal-code": "^1.0.3",
    "svgo": "4.0.1",
    "ts-node": "^10.9.2",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}