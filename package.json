{
  "name": "astro_template_webpage",
  "description": "📦️ This repository that contains an Astro template ready for any website you can imagine. It's like a Swiss Army knife for developers, offering pre-built modules and flexible configurations to kickstart your project, regardless of its type.",
  "author": "Luis Monsalve <TheElegantCoder>, Astralys Software <astralysoftware.com>",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "astro dev",
    "check": "astro check",
    "preview": "astro preview",
    "build": "rm -rf ./dist && astro check && astro build",
    "lint": "bun lint:eslint && bun lint:stylelint && bun lint:terraform",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint ./src/**/*.{scss,css} --fix",
    "lint:terraform": "terraform -chdir=infrastructure fmt -check && terraform -chdir=infrastructure validate",
    "compress:convert": "bun compress:svg && bun convert:image && bun convert:typography",
    "compress:svg": "bun ./script/compression/svg.ts",
    "convert:typography": "bun ./script/conversion/typography.ts",
    "convert:image": "bun ./script/conversion/image.ts",
    "tf:init": "terraform -chdir=infrastructure init",
    "tf:plan:dev": "terraform -chdir=infrastructure plan -var-file=dev.tfvars -out=dev.tfplan",
    "tf:apply:dev": "terraform -chdir=infrastructure apply \"dev.tfplan\"",
    "tf:destroy:dev": "terraform -chdir=infrastructure destroy -var-file=dev.tfvars",
    "tf:plan:prod": "terraform -chdir=infrastructure plan -var-file=prod.tfvars -out=prod.tfplan",
    "tf:apply:prod": "terraform -chdir=infrastructure apply \"prod.tfplan\"",
    "tf:destroy:prod": "terraform -chdir=infrastructure destroy -var-file=prod.tfvars",
    "deploy": "bun ./infrastructure/deploy.ts"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/partytown": "2.1.6",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fullhuman/postcss-purgecss": "8.0.0",
    "@types/node": "25.5.0",
    "@types/ttf2woff": "^2.0.4",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "6.1.3",
    "astro-class-shortener": "^1.0.3",
    "astro-inline-css": "^1.1.0",
    "autoprefixer": "10.4.27",
    "beasties": "^0.4.1",
    "dotenv": "^17.4.0",
    "dotenv-expand": "^12.0.3",
    "eslint-config-universal-code": "^1.0.9",
    "lenis": "^1.3.21",
    "postcss": "8.5.8",
    "postcss-combine-media-query": "^2.1.0",
    "sass": "1.98.0",
    "sharp": "^0.34.5",
    "stylelint-config-universal-code": "^1.0.3",
    "svgo": "4.0.1",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.2"
  }
}